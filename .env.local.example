# -- Distribution
export DISTRO=ubuntu  # ubuntu or arch

# -- Git Identity
export GIT_AUTHOR_NAME="[NAME]"
export GIT_AUTHOR_EMAIL="[EMAIL_ADDRESS]"
export GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
export GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"

# -- API Keys
export ANTHROPIC_API_KEY=""
export GITHUB_TOKEN=""

# -- Languages
export LANGUAGE_JAVASCRIPT=false
export LANGUAGE_GO=false

# -- Apps
export APPS_OBSIDIAN=false
export APPS_ANTIGRAVITY=false
export APPS_GHOSTTY=false
export APPS_OPENCODE=false
export APPS_OLLAMA=false
